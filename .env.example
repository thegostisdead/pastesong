# Optional — used as a fallback to find Spotify links when Odesli doesn't return one.
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional — used for rate limiting (20 req/60s per IP).
# Create a Redis database on Vercel and run `vercel env pull .env.local` to get this.
REDIS_URL=
